# ==================================================================== #
# Arquivo .env                                                         #
# Contém todas as variáveis de ambiente necessárias para               #
# execução das automações RPA.                                         #
#                                                                      #
# ATENÇÃO:                                                             #
# 1. Não compartilhe este arquivo publicamente (contém credenciais).   #
# 2. Não faça commit no GitHub de arquivos com senhas em texto plano.  #
# 3. Sempre faça o build do executavel após alterar variáveis.         # 
# ==================================================================== #

# ===================== #
# Configurações gerais  #
# ===================== #
API_URL="https://{subdominio_do_ambiente}.goevo.net/API/v1/?{nomedocliente}/RPAManager" # URL base da API utilizada pelas automações. (OBRIGATÓRIO)
GOEVO_APP_TPTOKEN="" # Token de autenticação do app no GOEVO (OBRIGATÓRIO)
RPA_EXECUTOR="SRV_RPA_001" # Identificador do executor RPA (nome do servidor ou agente)
GRPA_AUTOMATION_VERSION="2.0.0.20260326"
ENV="DOCKER" # Identificador se está rodando via docker ou não [usado para trocar o modo headless do modo com janela] (OPCIONAL)



# =================== #
# Variáveis dinamicas #
# =================== #
APPLICATION=""
SEARCH_TIMEOUT="60"
SYSTEM_URL=""
USER=""
PASSWORD=""